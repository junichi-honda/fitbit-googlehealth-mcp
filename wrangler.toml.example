name = "fitbit-googlehealth-mcp"
main = "src/index.ts"
compatibility_date = "2025-11-01"
compatibility_flags = ["nodejs_compat"]

[vars]
# Anthropic's published outbound CIDR for Claude → MCP server connections.
ALLOWED_CIDRS = "160.79.104.0/21"

# Which backend serves the MCP tools:
#   "google" — Google Health API v4 (health.googleapis.com), the Fitbit successor
#   "fitbit" — legacy Fitbit Web API (api.fitbit.com, shuts down 2026-09)
# The Worker defaults to "fitbit" when this var is unset, so existing
# deployments keep working. Flip to "google" after `pnpm run setup:google`
# has populated TOKENS with Google OAuth tokens.
HEALTH_PROVIDER = "google"

# Create both KV namespaces before `wrangler deploy`:
#   wrangler kv namespace create TOKENS
#   wrangler kv namespace create CACHE
# Then paste the returned ids below.

[[kv_namespaces]]
binding = "TOKENS"
id = "<your-tokens-namespace-id>"

[[kv_namespaces]]
binding = "CACHE"
id = "<your-cache-namespace-id>"

# Set the following secrets:
#   wrangler secret put GOOGLE_CLIENT_ID
#   wrangler secret put GOOGLE_CLIENT_SECRET
#   wrangler secret put MCP_SHARED_SECRET   # `openssl rand -hex 32`; sent by the
#     client as `Authorization: Bearer <secret>` (legacy: path segment of /mcp/:secret)
# Only needed while HEALTH_PROVIDER = "fitbit":
#   wrangler secret put FITBIT_CLIENT_ID
#   wrangler secret put FITBIT_CLIENT_SECRET
